# ServiceChannel OAuth credentials (from your app registration)
SC_CLIENT_ID=your_client_id_here
SC_CLIENT_SECRET=your_client_secret_here

# This MUST match exactly what you entered as Callback URI during app registration
# Replace with your actual Railway/Render URL after deployment
SC_REDIRECT_URI=https://YOUR-APP.up.railway.app/auth/callback

# ServiceChannel endpoints (leave as-is for production; change to sb2 URLs for sandbox)
SC_AUTH_BASE=https://login.servicechannel.com
SC_API_BASE=https://api.servicechannel.com

# Strong random secret — protects /auth/token, /auth/refresh, /sc/* endpoints
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET=generate_a_strong_random_value_here

# Microsoft Teams workflow/incoming webhook URL for work order alerts
TEAMS_WEBHOOK_URL=https://example.webhook.office.com/...

# Notion integration — create at https://www.notion.so/my-integrations
# After creating, share the WO Tracker database with the integration (Share → Connections)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=98790a991cfb442d8a92dfb6d2004e04

# Notification schedule/time zone and stale-work-order thresholds
NOTIFY_TZ=America/Chicago
STALE_DAYS=60
FOLLOWUP_DAYS=14
SC_TIMEOUT_SECONDS=90
